{
  "name": "@jerrythomas/dbd",
  "version": "2.0.0",
  "description": "Deploy databases using DDL scripts.",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "adapters/*"
  ],
  "bin": {
    "dbd": "packages/cli/src/index.js"
  },
  "scripts": {
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write .",
    "build": "npm run build --workspaces",
    "test:parser": "npm test --workspace=packages/parser",
    "test:cli": "npm test --workspace=packages/cli",
    "test:db": "npm test --workspace=packages/db",
    "test:dbml": "npm test --workspace=packages/dbml",
    "test:postgres": "npm test --workspace=adapters/postgres",
    "test:workspaces": "npm test --workspaces",
    "pg-test": "docker run --name pg-test -p 5234:5432 -e POSTGRES_PASSWORD=pg-test -d postgres",
    "test:e2e": "npm run test:e2e --workspace=packages/cli",
    "test:pg": "bun pg-test && bun test:e2e && bun test:clean",
    "test:clean": "docker stop pg-test && docker rm pg-test",
    "test": "bun pg-test && bun test:unit && bun test:e2e && bun test:clean",
    "release:next": "release-it --preRelease=next",
    "release": "release-it",
    "test:unit": "npm test --workspaces",
    "test:nopg": "npm test --workspaces"
  },
  "author": "Jerry Thomas <me@jerrythomas.name>",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@vanillaes/mock-console": "^3.0.0",
    "@vitest/coverage-v8": "^3.2.2",
    "eslint": "^9.28.0",
    "prettier": "^3.5.3",
    "release-it": "^19.0.3",
    "rimraf": "^6.0.1",
    "vite": "^6.3.5",
    "vitest": "^3.2.2"
  }
}
