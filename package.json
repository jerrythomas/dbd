{
  "name": "@jerrythomas/dbd",
  "version": "1.3.1",
  "description": "Deploy databases using DDL scripts.",
  "private": false,
  "type": "module",
  "workspaces": [
    "packages/*",
    "adapters/*"
  ],
  "bin": "src/index.js",
  "main": "src/index.js",
  "module": "src/index.js",
  "scripts": {
    "start": "src/index.js",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write .",
    "build": "npm run build --workspaces",
    "test:parser": "npm test --workspace=packages/parser",
    "test:cli": "npm test --workspace=packages/cli",
    "test:db": "npm test --workspace=packages/db",
    "test:dbml": "npm test --workspace=packages/dbml",
    "test:postgres": "npm test --workspace=adapters/postgres",
    "test:workspaces": "npm test --workspaces",
    "pg-test": "docker run --name pg-test -p 5234:5432 -e POSTGRES_PASSWORD=pg-test -d postgres",
    "test:pg": "bun pg-test && bun test ./spec/collect.spec.js && bun test:clean",
    "test:nopg": "find spec/*.spec.js | grep -v collect | xargs vitest",
    "test:clean": "docker stop pg-test && docker rm pg-test",
    "test": "bun pg-test && bun test:unit && bun test:clean",
    "release:next": "release-it --preRelease=next",
    "release": "release-it",
    "test:unit": "vitest",
    "coverage": "bun pg-test && vitest run --coverage && bun test:clean"
  },
  "author": "Jerry Thomas <me@jerrythomas.name>",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@databases/pg": "^5.5.0",
    "@dbml/core": "^3.13.5",
    "csvtojson": "^2.0.10",
    "js-yaml": "^4.1.0",
    "node-sql-parser": "^5.3.9",
    "ramda": "^0.30.1",
    "sade": "^1.8.1"
  },
  "devDependencies": {
    "@vanillaes/mock-console": "^3.0.0",
    "@vitest/coverage-v8": "^3.2.2",
    "eslint": "^9.28.0",
    "prettier": "^3.5.3",
    "release-it": "^19.0.3",
    "rimraf": "^6.0.1",
    "vite": "^6.3.5",
    "vitest": "^3.2.2"
  },
  "exports": {
    "./package.json": "./package.json",
    "./src": "./src",
    ".": {
      "import": "./src/index.js"
    }
  }
}
