{
  "name": "dbd-workspace",
  "version": "2.0.3",
  "description": "Deploy databases using DDL scripts.",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:parser": "vitest run --project postgres",
    "test:cli": "vitest run --project cli",
    "test:db": "vitest run --project db",
    "test:dbml": "vitest run --project dbml",
    "test:postgres": "vitest run --project postgres",
    "test:unit": "vitest run",
    "test:nopg": "vitest run",
    "coverage": "vitest run --coverage",
    "test:e2e": "vitest run --config packages/cli/vitest.e2e.config.js",
    "pg-test": "docker run --name pg-test -p 5234:5432 -e POSTGRES_PASSWORD=pg-test -d postgres",
    "test:pg": "bun pg-test && bun test:e2e && bun test:clean",
    "test:clean": "docker stop pg-test && docker rm pg-test",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write .",
    "bump": "bumpp --no-push",
    "bump:next": "bumpp --preid=next --no-push",
    "publish:all": "find ./packages -type d -depth 1 -exec sh -c 'cd \"{}\" && bun publish' \\;",
    "release": "bun run publish:all"
  },
  "author": "Jerry Thomas <me@jerrythomas.name>",
  "license": "MIT",
  "devDependencies": {
    "@vanillaes/mock-console": "^3.0.0",
    "@vitest/coverage-v8": "^3.2.2",
    "bumpp": "^10.4.1",
    "eslint": "^9.28.0",
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1",
    "vite": "^6.3.5",
    "vitest": "^3.2.2"
  }
}
