{
  "name": "@jerrythomas/dbd-dbml",
  "version": "1.2.8",
  "description": "DBML conversion and publishing utilities for DBD.",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "test": "vitest",
    "test:ci": "vitest run",
    "coverage": "vitest run --coverage",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write ."
  },
  "keywords": [
    "database",
    "dbml",
    "conversion",
    "dbdocs",
    "schema",
    "documentation"
  ],
  "author": "Jerry Thomas <me@jerrythomas.name>",
  "license": "MIT",
  "dependencies": {
    "@jerrythomas/dbd-parser": "workspace:*",
    "@dbml/core": "^3.13.5",
    "ramda": "^0.30.1"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.2",
    "eslint": "^9.28.0",
    "prettier": "^3.5.3",
    "vitest": "^3.2.2"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": "./src/index.js"
    },
    "./package.json": "./package.json"
  }
}