{
  "name": "@jerrythomas/dbd-cli",
  "version": "2.0.0",
  "description": "Command line interface for database design and deployment.",
  "type": "module",
  "main": "src/index.js",
  "bin": {
    "dbd": "src/index.js"
  },
  "scripts": {
    "test": "vitest",
    "test:ci": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.js",
    "coverage": "vitest run --coverage",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write ."
  },
  "keywords": [
    "database",
    "ddl",
    "cli",
    "deployment",
    "schema"
  ],
  "author": "Jerry Thomas <me@jerrythomas.name>",
  "license": "MIT",
  "dependencies": {
    "@jerrythomas/dbd-parser": "workspace:*",
    "@jerrythomas/dbd-db": "workspace:*",
    "@jerrythomas/dbd-dbml": "workspace:*",
    "sade": "^1.8.1",
    "js-yaml": "^4.1.0",
    "ramda": "^0.30.1"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.2",
    "eslint": "^9.28.0",
    "prettier": "^3.5.3",
    "vitest": "^3.2.2"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": "./src/index.js"
    },
    "./package.json": "./package.json"
  }
}
