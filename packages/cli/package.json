{
  "name": "@jerrythomas/dbd",
  "version": "2.0.4",
  "description": "Command line interface for database design and deployment.",
  "type": "module",
  "main": "src/index.js",
  "bin": {
    "dbd": "src/index.js"
  },
  "scripts": {
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.js",
    "coverage": "vitest run --coverage",
    "prepublishOnly": "cp ../../LICENSE .",
    "postpublish": "rm LICENSE"
  },
  "keywords": [
    "database",
    "ddl",
    "cli",
    "deployment",
    "schema"
  ],
  "author": "Jerry Thomas <me@jerrythomas.name>",
  "license": "MIT",
  "dependencies": {
    "@jerrythomas/dbd-db": "workspace:*",
    "@jerrythomas/dbd-dbml": "workspace:*",
    "@jerrythomas/dbd-postgres-adapter": "workspace:*",
    "sade": "^1.8.1",
    "js-yaml": "^4.1.0",
    "ramda": "^0.30.1"
  },
  "devDependencies": {},
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": "./src/index.js"
    },
    "./package.json": "./package.json"
  }
}
